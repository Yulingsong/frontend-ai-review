{
  "name": "frontend-ai-review",
  "version": "2.3.2",
  "description": "AI-powered code review tool for frontend developers",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "cjs": "dist-cjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./rules": {
      "import": "./dist/rules/index.js",
      "require": "./dist-cjs/rules/index.js"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist-cjs/utils/index.js"
    },
    "./llm": {
      "import": "./dist/llm/index.js",
      "require": "./dist-cjs/llm/index.js"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist-cjs/types/index.js"
    }
  },
  "bin": {
    "fair": "./bin/fair"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:watch": "tsc --watch",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --reporter=dot",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-cjs coverage",
    "clean:all": "rm -rf dist dist-cjs coverage node_modules",
    "prepublish": "npm run build",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run"
  },
  "keywords": [
    "frontend",
    "code-review",
    "ai",
    "react",
    "vue",
    "typescript",
    "eslint",
    "linter"
  ],
  "author": "Yulingsong",
  "license": "MIT",
  "dependencies": {
    "glob": "^11.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/Yulingsong/frontend-ai-review/issues"
  },
  "homepage": "https://github.com/Yulingsong/frontend-ai-review#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yulingsong/frontend-ai-review.git"
  }
}
