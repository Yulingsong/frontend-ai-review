{
  "name": "frontend-ai-review",
  "version": "2.3.0",
  "description": "AI-powered code review tool for frontend developers",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "cjs": "dist-cjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./rules": {
      "import": "./dist/rules/index.js",
      "require": "./dist-cjs/rules/index.js"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist-cjs/utils/index.js"
    },
    "./llm": {
      "import": "./dist/llm/index.js",
      "require": "./dist-cjs/llm/index.js"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist-cjs/types/index.js"
    }
  },
  "bin": {
    "fair": "./bin/fair"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublish": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "frontend",
    "code-review",
    "ai",
    "react",
    "vue",
    "typescript",
    "eslint",
    "linter"
  ],
  "author": "Yulingsong",
  "license": "MIT",
  "dependencies": {
    "glob": "^11.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/Yulingsong/frontend-ai-review/issues"
  },
  "homepage": "https://github.com/Yulingsong/frontend-ai-review#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yulingsong/frontend-ai-review.git"
  }
}
