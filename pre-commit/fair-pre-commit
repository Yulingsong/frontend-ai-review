#!/bin/sh
# Fair Pre-commit Hook
# 安装到 .git/hooks/pre-commit

# 检查是否安装了 fair
if ! command -v fair &> /dev/null; then
  echo "❌ fair not found. Install: npm install -g frontend-ai-review"
  exit 1
fi

# 获取暂存的文件
FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx|vue)$')

if [ -z "$FILES" ]; then
  echo "✅ No files to review"
  exit 0
fi

echo "🤖 Running Frontend AI Review..."

# 运行 fair
RESULT=$(fair . -s warning -o text 2>&1)

if [ $? -eq 0 ]; then
  echo "✅ Code review passed"
  exit 0
else
  echo "❌ Code review failed"
  echo "$RESULT"
  exit 1
fi
